{
  "name": "@kontourai/forage",
  "version": "0.4.2",
  "description": "Safe, replayable web crawling for review pipelines — a crawler for untrusted URLs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/forage.git"
  },
  "homepage": "https://github.com/kontourai/forage#readme",
  "bugs": {
    "url": "https://github.com/kontourai/forage/issues"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./egress": {
      "types": "./dist/src/egress-index.d.ts",
      "default": "./dist/src/egress-index.js"
    },
    "./fetch": {
      "types": "./dist/src/fetch-index.d.ts",
      "default": "./dist/src/fetch-index.js"
    }
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepare": "npm run build",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "test:release-tag-ancestry": "scripts/check-release-tag-ancestry.sh --self-test",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test && npm run test:release-tag-ancestry"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": ">=5.0.0"
  }
}
