{
  "name": "@kontourai/forage",
  "version": "0.0.0",
  "description": "Safe, replayable web crawling for review pipelines — a crawler for untrusted URLs.",
  "type": "module",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepare": "npm run build",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": ">=5.0.0"
  }
}
